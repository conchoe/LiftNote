# Copy to .env in this folder (my-app/) and fill in from Supabase:
# Dashboard → Project Settings → API → URL + Publishable (or legacy anon) key
#
# Email confirmation links: Dashboard → Authentication → URL Configuration → Redirect URLs
# must include myapp://** (see app.json "scheme") and exp://** if you use Expo Go.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
